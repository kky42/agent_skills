    "ask-matt": {
      "path": "skills/thirdparty/ask-matt",
      "ownership": "mirror",
      "mirror": {
        "source": "mattpocock/skills",
        "path": "skills/engineering/ask-matt"
      }
    },
    "chatgpt": {
      "path": "skills/chatgpt",
      "ownership": "owned",
      "relations": [
        {
          "id": "playwright-cli",
          "type": "skill-dependency",
          "skill": "playwright-cli",
          "verify": [
            [
              "playwright-cli",
              "--help"
            ]
          ]
        },
        {
          "id": "playwright-cli-tool",
          "type": "tool-dependency",
          "tool": {
            "kind": "npm-global",
            "package": "@playwright/cli",
            "constraint": ">=0.1.15"
          },
          "updatePolicy": "compatible",
          "verify": [
            [
              "playwright-cli",
              "--version"
            ],
            [
              "playwright-cli",
              "--help"
            ]
          ]
        },
        {
          "id": "chatgpt-local-helpers",
          "type": "tool-dependency",
          "tool": {
            "kind": "local-helper",
            "name": "chatgpt-local-helpers",
            "path": "scripts"
          },
          "updatePolicy": "manual",
          "verify": [
            [
              "python3",
              "scripts/chatgpt-pw-lock",
              "--help"
            ],
            [
              "node",
              "--check",
              "scripts/deep-research-extract-current.js"
            ]
          ]
        }
      ]
    },
