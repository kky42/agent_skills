    "kaggle": {
      "path": "skills/datascience/kaggle",
      "ownership": "owned",
      "relations": [
        {
          "id": "nvidia-kaggle",
          "type": "content-source",
          "source": {
            "source": "NVIDIA/nvidia-kaggle",
            "path": "skills/nvidia-kaggle-skill"
          },
          "watch": {
            "include": [
              "**"
            ],
            "localPaths": [
              "SKILL.md",
              "refs/**",
              "scripts/nvidia/**"
            ],
            "localConcerns": [
              {
                "id": "nvidia-methodology-and-helpers",
                "description": "Selectively adapt NVIDIA methodology and helper changes while preserving local validation, safety, and compatibility policy."
              }
            ]
          }
        },
        {
          "id": "kaggle-cli-contract",
          "type": "reference",
          "source": {
            "source": "Kaggle/kaggle-cli",
            "path": "src/kaggle"
          },
          "watch": {
            "include": [
              "cli.py",
              "api/**"
            ],
            "localPaths": [
              "SKILL.md",
              "refs/cli/**",
              "refs/scripts/**",
              "scripts/**"
            ],
            "localConcerns": [
              {
                "id": "kaggle-cli-compatibility",
                "description": "Review Kaggle CLI command and API changes that affect documented commands or native wrappers."
              }
            ]
          }
        },
        {
          "id": "playwright-cli",
          "type": "skill-dependency",
          "skill": "playwright-cli",
          "verify": [
            [
              "playwright-cli",
              "--help"
            ]
          ]
        },
        {
          "id": "kaggle-cli-tool",
          "type": "tool-dependency",
          "tool": {
            "kind": "command",
            "name": "kaggle"
          },
          "updatePolicy": "compatible",
          "verify": [
            [
              "kaggle",
              "--version"
            ],
            [
              "kaggle",
              "competitions",
              "--help"
            ]
          ]
        }
      ]
    },
