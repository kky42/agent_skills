#!/usr/bin/env python3
"""Inspect the normalized ownership, source, skill, and tool relation graph."""
from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
from pathlib import Path

from skill_model import (
    ModelError,
    catalog_summary,
    dependency_graph,
    load_catalog,
)


def relation_label(relation: dict) -> str:
    relation_type = relation.get("type")
    if relation_type == "skill-dependency":
        return f"skill:{relation.get('skill')}"
    if relation_type == "tool-dependency":
        tool = relation.get("tool") or {}
        target = tool.get("name") or tool.get("package") or tool.get("path") or tool.get("kind")
        return f"tool:{target}"
    source = relation.get("source") or {}
    target = source.get("source") or source.get("skill") or "?"
    path = source.get("path")
    return f"{relation_type}:{target}{':' + path if path else ''}"


def check(catalog, output_format: str) -> int:
    summary = catalog_summary(catalog)
    result = {"ok": True, **summary}
    if output_format == "json":
        print(json.dumps(result, ensure_ascii=False, sort_keys=True))
    else:
        ownership = summary["ownership"]
        print(
            f"ok: {summary['skills']} skills; "
            f"ownership mirror={ownership['mirror']}, owned={ownership['owned']} "
            f"({summary['explicitOwnership']} explicit, "
            f"{summary['legacySourceRecords']} legacy source records)"
        )
    return 0


def list_deps(catalog, output_format: str) -> int:
    dependencies, reverse = dependency_graph(catalog)
    rows = []
    for name, record in sorted(catalog.skills.items()):
        rows.append(
            {
                "name": name,
                "path": record.relative_path,
                "ownership": record.ownership,
                "ownershipExplicit": record.ownership_explicit,
                "legacySource": record.legacy_source,
                "dependsOn": sorted(dependencies.get(name, [])),
                "usedBy": sorted(reverse.get(name, [])),
                "relations": [
                    {
                        "id": relation.get("id"),
                        "type": relation.get("type"),
                        "label": relation_label(relation),
                        "origin": relation.get("origin"),
                        "verify": relation.get("verify") or [],
                        "updatePolicy": relation.get("updatePolicy"),
                    }
                    for relation in record.relations
                ],
            }
        )
    if output_format == "json":
        print(json.dumps({"skills": rows}, ensure_ascii=False, sort_keys=True))
        return 0
    for row in rows:
        marker = "explicit" if row["ownershipExplicit"] else "default"
        if row["legacySource"] and not row["ownershipExplicit"]:
            marker += ", legacy source"
        depends = ", ".join(row["dependsOn"]) or "-"
        used_by = ", ".join(row["usedBy"]) or "-"
        relations = ", ".join(item["label"] for item in row["relations"]) or "-"
        print(
            f"{row['name']}\n"
            f"  ownership: {row['ownership']} ({marker})\n"
            f"  depends: {depends}\n"
            f"  used by: {used_by}\n"
            f"  relations: {relations}"
        )
    return 0


def why(catalog, name: str, output_format: str) -> int:
    if name not in catalog.skills:
        raise ModelError(f"unknown skill: {name}")
    dependencies, reverse = dependency_graph(catalog)
    record = catalog.skills[name]
    result = {
        "name": name,
        "path": record.relative_path,
        "ownership": record.ownership,
        "ownershipExplicit": record.ownership_explicit,
        "legacySource": record.legacy_source,
        "dependsOn": sorted(dependencies.get(name, [])),
        "usedBy": sorted(reverse.get(name, [])),
        "relations": [
            {
                "id": relation.get("id"),
                "type": relation.get("type"),
                "label": relation_label(relation),
                "origin": relation.get("origin"),
                "verify": relation.get("verify") or [],
                "updatePolicy": relation.get("updatePolicy"),
            }
            for relation in record.relations
        ],
    }
    if output_format == "json":
        print(json.dumps(result, ensure_ascii=False, sort_keys=True))
        return 0
    marker = "explicit" if record.ownership_explicit else "default"
    print(f"{name}: {record.path}")
    print(f"ownership: {record.ownership} ({marker})")
    print("depends on:")
    for dependency in result["dependsOn"] or ["-"]:
        print(f"  {dependency}")
    print("used by:")
    for dependent in result["usedBy"] or ["-"]:
        print(f"  {dependent}")
    print("relations:")
    for relation in result["relations"] or [{"label": "-", "id": "-"}]:
        suffix = f" [{relation['id']}]" if relation.get("id") != "-" else ""
        print(f"  {relation['label']}{suffix}")
    return 0


def parse_semver(value: str) -> tuple[int, int, int] | None:
    match = re.match(r"^[vV]?(\d+)\.(\d+)\.(\d+)", value)
    if not match:
        return None
    return tuple(int(part) for part in match.groups())


def version_satisfies(version: str, constraint: str) -> bool | None:
    actual = parse_semver(version)
    if actual is None:
        return None
    constraint = constraint.strip()
    if constraint in {"", "*", "latest"}:
        return True
    if constraint.startswith("^"):
        lower = parse_semver(constraint[1:])
        if lower is None:
            return None
        if lower[0] > 0:
            upper = (lower[0] + 1, 0, 0)
        elif lower[1] > 0:
            upper = (0, lower[1] + 1, 0)
        else:
            upper = (0, 0, lower[2] + 1)
        return lower <= actual < upper
    if constraint.startswith("~"):
        lower = parse_semver(constraint[1:])
        if lower is None:
            return None
        return lower <= actual < (lower[0], lower[1] + 1, 0)
    clauses = [clause for clause in re.split(r"[ ,]+", constraint) if clause]
    for clause in clauses:
        match = re.fullmatch(r"(>=|<=|>|<|=)?[vV]?(\d+)\.(\d+)\.(\d+)(?:[-+].*)?", clause)
        if not match:
            return None
        operator = match.group(1) or "="
        expected = tuple(int(part) for part in match.groups()[1:])
        if operator == ">=" and not actual >= expected:
            return False
        if operator == "<=" and not actual <= expected:
            return False
        if operator == ">" and not actual > expected:
            return False
        if operator == "<" and not actual < expected:
            return False
        if operator == "=" and not actual == expected:
            return False
    return True


def npm_global_version(package: str) -> tuple[str | None, str | None]:
    try:
        process = subprocess.run(
            ["npm", "root", "-g"],
            text=True,
            capture_output=True,
            timeout=30,
        )
    except (OSError, subprocess.TimeoutExpired) as error:
        return None, str(error)
    if process.returncode != 0:
        return None, (process.stderr or process.stdout).strip()
    package_json = Path(process.stdout.strip()) / package / "package.json"
    if not package_json.exists():
        return None, f"global npm package is not installed: {package}"
    try:
        value = json.loads(package_json.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as error:
        return None, str(error)
    version = value.get("version")
    if not isinstance(version, str):
        return None, f"{package_json}: version is missing"
    return version, None


def affected_skills(catalog, name: str | None) -> list[str]:
    if name is None:
        return sorted(catalog.skills)
    if name not in catalog.skills:
        raise ModelError(f"unknown skill: {name}")
    _, reverse = dependency_graph(catalog)
    selected = {name}
    queue = [name]
    while queue:
        current = queue.pop(0)
        for dependent in sorted(reverse.get(current, [])):
            if dependent not in selected:
                selected.add(dependent)
                queue.append(dependent)
    return sorted(selected)


def verify(catalog, name: str | None, output_format: str, *, strict: bool = False) -> int:
    selected = affected_skills(catalog, name)
    results = []
    unchecked = []
    for skill_name in selected:
        record = catalog.skills[skill_name]
        for relation in record.relations:
            relation_id = relation.get("id")
            relation_type = relation.get("type")
            if relation_type not in {"skill-dependency", "tool-dependency"}:
                continue
            check_start = len(results)
            if relation_type == "tool-dependency":
                tool = relation.get("tool") or {}
                if tool.get("kind") == "npm-global" and tool.get("package"):
                    version, error = npm_global_version(tool["package"])
                    constraint = tool.get("constraint") or "*"
                    satisfies = None if error else version_satisfies(version, constraint)
                    if satisfies is None and not error:
                        error = f"unsupported version constraint: {constraint}"
                    results.append(
                        {
                            "skill": skill_name,
                            "relation": relation_id,
                            "kind": "tool-version",
                            "target": tool["package"],
                            "constraint": constraint,
                            "version": version,
                            "ok": bool(satisfies) and not error,
                            "detail": error or f"installed {version}",
                        }
                    )
            for command in relation.get("verify") or []:
                try:
                    process = subprocess.run(
                        command,
                        cwd=str(record.path),
                        text=True,
                        capture_output=True,
                        timeout=120,
                    )
                    ok = process.returncode == 0
                    detail = (process.stdout or process.stderr or "").strip()[-4000:]
                except (OSError, subprocess.TimeoutExpired) as error:
                    ok = False
                    detail = str(error)
                results.append(
                    {
                        "skill": skill_name,
                        "relation": relation_id,
                        "kind": "command",
                        "command": command,
                        "ok": ok,
                        "detail": detail,
                    }
                )
            if len(results) == check_start:
                unchecked.append(
                    {
                        "skill": skill_name,
                        "relation": relation_id,
                        "type": relation_type,
                        "target": relation.get("skill") or (relation.get("tool") or {}).get("package") or (relation.get("tool") or {}).get("name"),
                    }
                )
    ok = all(result["ok"] for result in results) and (not strict or not unchecked)
    report = {
        "ok": ok,
        "requestedSkill": name,
        "affectedSkills": selected,
        "checks": results,
        "uncheckedRelations": unchecked,
        "strict": strict,
    }
    if output_format == "json":
        print(json.dumps(report, ensure_ascii=False, sort_keys=True))
    else:
        if not results:
            print(f"ok: no verify checks declared for {', '.join(selected)}")
        for result in results:
            marker = "ok" if result["ok"] else "FAIL"
            target = result.get("target") or " ".join(result.get("command") or [])
            print(f"{marker}: {result['skill']} [{result['relation']}] {target}: {result['detail']}")
        for relation in unchecked:
            marker = "FAIL" if strict else "unchecked"
            print(f"{marker}: {relation['skill']} [{relation['relation']}] {relation['target']}: no compatibility verify declared")
    return 0 if ok else 1


def dot(catalog) -> int:
    dependencies, _ = dependency_graph(catalog)
    print("digraph skills {")
    for name in sorted(catalog.skills):
        print(f'  "{name}";')
    for name, names in sorted(dependencies.items()):
        for dependency in sorted(names):
            print(f'  "{name}" -> "{dependency}";')
    print("}")
    return 0


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("command", nargs="?", default="check", choices=["check", "list", "why", "verify", "dot"])
    parser.add_argument("name", nargs="?")
    parser.add_argument("--format", choices=["text", "json"], default="text")
    parser.add_argument("--strict", action="store_true", help="fail verify when a dependency relation has no declared check")
    args = parser.parse_args(argv[1:])
    if args.command == "why" and not args.name:
        parser.error("why requires a skill name")
    if args.command not in {"why", "verify"} and args.name:
        parser.error(f"{args.command} does not accept a skill name")
    if args.command == "dot" and args.format != "text":
        parser.error("dot only supports text output")
    if args.strict and args.command != "verify":
        parser.error("--strict is only valid with verify")
    return args


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    try:
        catalog = load_catalog(os.environ.get("AGENT_SKILLS_REPO_ROOT"))
        if args.command == "check":
            return check(catalog, args.format)
        if args.command == "list":
            return list_deps(catalog, args.format)
        if args.command == "why":
            return why(catalog, args.name, args.format)
        if args.command == "verify":
            return verify(catalog, args.name, args.format, strict=args.strict)
        return dot(catalog)
    except ModelError as error:
        if args.format == "json":
            print(json.dumps({"ok": False, "error": str(error)}, ensure_ascii=False))
        else:
            print(str(error), file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
