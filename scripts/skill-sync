#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
default_skill_targets="$HOME/.agents/skills:$HOME/.claude/skills"
sync_skills=1
sync_tools=1
check_only=0

if [ -z "${AGENT_SKILLS_SKILL_TARGETS:-}" ]; then
  AGENT_SKILLS_SKILL_TARGETS="${AGENT_HUB_SKILL_TARGETS:-$default_skill_targets}"
fi
export AGENT_SKILLS_SKILL_TARGETS

usage() {
  cat <<'EOF'
Usage:
  ./scripts/skill-sync [--skills-only|--tools-only|--no-tools|--check]

This repo is the canonical source for both personal and vendored third-party
skills. Third-party skills are updated by agent-reviewed upstream diffs into
skills/thirdparty/, not by blind npx skills installs.

Options:
  --skills-only      Link repo skills only; skip tool/plugin install.
  --personal-only    Back-compat alias for --skills-only.
  --private-only     Back-compat alias for --skills-only.
  --tools-only       Install declared tools/plugins only; skip skill links.
  --no-tools         Link repo skills and skip tool/plugin install.
  --check            Validate metadata/dependencies without changing links/tools.
  -h, --help         Show this help.

Deprecated:
  --thirdparty-only, --install, --remove are no longer supported. Edit
  thirdparty-skills.yml + skills/thirdparty/ manually, then run skill-sync.
EOF
}

die() {
  echo "$1" >&2
  usage >&2
  exit 1
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --skills-only|--personal-only|--private-only)
      sync_skills=1
      sync_tools=0
      shift
      ;;
    --tools-only)
      sync_skills=0
      sync_tools=1
      shift
      ;;
    --no-tools)
      sync_tools=0
      shift
      ;;
    --check)
      check_only=1
      shift
      ;;
    --thirdparty-only|--install|--remove|--install=*|--remove=*)
      die "$1 is deprecated: third-party skills are vendored under skills/thirdparty and updated by agent-reviewed diffs"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required" >&2
  exit 1
fi

python3 - "$repo_root" "$AGENT_SKILLS_SKILL_TARGETS" "$sync_skills" "$sync_tools" "$check_only" <<'PY'
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
skills_root = repo_root / "skills"
target_roots = [
    Path(os.path.expanduser(item)).resolve()
    for item in sys.argv[2].split(os.pathsep)
    if item
]
sync_skills = sys.argv[3] == "1"
sync_tools = sys.argv[4] == "1"
check_only = sys.argv[5] == "1"
legacy_roots = target_roots + [Path.home() / ".pi" / "agent" / "skills"]


def under(path: Path, parent: Path) -> bool:
    try:
        path.relative_to(parent)
        return True
    except ValueError:
        return False


def resolve(path: Path) -> Path:
    return path.resolve(strict=False)


def clean_scalar(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
        return value[1:-1]
    return value


def frontmatter_name(skill_md: Path):
    lines = skill_md.read_text(encoding="utf-8").splitlines()
    if not lines or lines[0].strip() != "---":
        return None
    for line in lines[1:]:
        if line.strip() == "---":
            return None
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or ":" not in stripped:
            continue
        key, value = stripped.split(":", 1)
        if key.strip() == "name":
            name = clean_scalar(value)
            return str(name) if name else None
    return None


def load_meta(skill_dir: Path) -> dict:
    path = skill_dir / "skill.meta.json"
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as err:
        raise SystemExit(f"{path}: invalid JSON: {err}")
    if not isinstance(data, dict):
        raise SystemExit(f"{path}: expected a JSON object")
    return data


def discover_skills():
    desired = {}
    metas = {}
    for skill_md in sorted(skills_root.rglob("SKILL.md")):
        skill_dir = skill_md.parent.resolve()
        name = skill_dir.name
        if name in desired:
            raise SystemExit(
                f"duplicate skill directory name: {name}\n"
                f"  {desired[name]}\n"
                f"  {skill_dir}"
            )
        declared_name = frontmatter_name(skill_md)
        if declared_name and declared_name != name:
            raise SystemExit(
                f"{skill_md}: frontmatter name {declared_name!r} "
                f"does not match directory name {name!r}"
            )
        desired[name] = skill_dir
        meta = load_meta(skill_dir)
        if meta:
            if meta.get("name") and meta.get("name") != name:
                raise SystemExit(f"{skill_dir/'skill.meta.json'}: name must be {name!r}")
            metas[name] = meta
    return desired, metas


def validate_dependencies(desired: dict, metas: dict):
    errors = []
    for name, meta in sorted(metas.items()):
        for dep in meta.get("dependsOnSkills", []) or []:
            if dep not in desired:
                errors.append(f"{name}: missing skill dependency {dep!r}")
        for tool in meta.get("dependsOnTools", []) or []:
            if not isinstance(tool, dict):
                errors.append(f"{name}: dependsOnTools entries must be objects")
                continue
            if tool.get("kind") == "opencli-plugin":
                rel = tool.get("path")
                plugin_name = tool.get("name")
                if not rel or not plugin_name:
                    errors.append(f"{name}: opencli-plugin tool requires name and path")
                    continue
                path = (desired[name] / rel).resolve()
                if not path.exists():
                    errors.append(f"{name}: opencli-plugin {plugin_name!r} path does not exist: {path}")
                if not (path / "opencli-plugin.json").exists():
                    errors.append(f"{name}: opencli-plugin {plugin_name!r} missing opencli-plugin.json at {path}")
    if errors:
        raise SystemExit("dependency validation failed:\n- " + "\n- ".join(errors))


def link_skills(desired: dict):
    seen_roots = set()
    for root in legacy_roots:
        root = root.resolve()
        if root in seen_roots:
            continue
        seen_roots.add(root)
        for legacy_name in ("agent_hub-private", "agent_hub_skills"):
            legacy_path = root / legacy_name
            if check_only:
                continue
            if legacy_path.is_symlink():
                legacy_path.unlink()
                print(f"removed legacy skill link: {legacy_path}", flush=True)
            elif legacy_path.is_dir():
                shutil.rmtree(legacy_path)
                print(f"removed legacy skill copy: {legacy_path}", flush=True)

    for target_root in target_roots:
        if check_only:
            continue
        target_root.mkdir(parents=True, exist_ok=True)
        for child in target_root.iterdir():
            if not child.is_symlink():
                continue
            linked_target = resolve(child)
            if not under(linked_target, skills_root):
                continue
            if child.name not in desired or resolve(desired[child.name]) != linked_target:
                child.unlink()
                print(f"removed stale skill link: {child}", flush=True)

        for name, source in sorted(desired.items()):
            target = target_root / name
            if target.exists() or target.is_symlink():
                if target.is_symlink():
                    linked_target = resolve(target)
                    if linked_target == resolve(source):
                        continue
                    if under(linked_target, skills_root):
                        target.unlink()
                    else:
                        raise SystemExit(
                            f"error: {target} already exists as an unmanaged symlink "
                            f"to {os.readlink(target)}"
                        )
                else:
                    may_replace_managed_copy = (
                        target.is_dir()
                        and (target / "SKILL.md").exists()
                        and (under(source, skills_root / "thirdparty") or os.environ.get("AGENT_SKILLS_REPLACE_EXISTING_SKILL_DIRS") == "1")
                    )
                    if may_replace_managed_copy:
                        shutil.rmtree(target)
                        print(f"replaced installed skill copy with repo link: {target}", flush=True)
                    else:
                        raise SystemExit(f"error: {target} already exists and is not an agent_skills symlink")
            os.symlink(source, target, target_is_directory=True)
            print(f"linked skill: {target} -> {source}", flush=True)


def iter_opencli_plugins(desired: dict, metas: dict):
    seen = {}
    for skill_name, meta in sorted(metas.items()):
        for tool in meta.get("dependsOnTools", []) or []:
            if not isinstance(tool, dict) or tool.get("kind") != "opencli-plugin":
                continue
            plugin_name = tool["name"]
            path = (desired[skill_name] / tool["path"]).resolve()
            if plugin_name in seen and seen[plugin_name] != path:
                raise SystemExit(f"opencli plugin {plugin_name!r} declared with multiple paths: {seen[plugin_name]} and {path}")
            seen[plugin_name] = path
    return sorted(seen.items())


def install_opencli_plugins(plugins):
    if not plugins:
        return
    if shutil.which("opencli") is None:
        raise SystemExit("opencli is required to install declared opencli-plugin tools")
    plugins_root = Path.home() / ".opencli" / "plugins"
    for name, source in plugins:
        target = plugins_root / name
        if check_only:
            print(f"would ensure opencli plugin: {name} -> {source}", flush=True)
            continue
        if target.exists() or target.is_symlink():
            if target.is_symlink() and resolve(target) == source:
                host_link = source / "node_modules" / "@jackwener" / "opencli"
                if host_link.exists() or host_link.is_symlink():
                    print(f"opencli plugin already linked: {name} -> {source}", flush=True)
                    continue
                print(f"repairing opencli plugin runtime link: {name}", flush=True)
                subprocess.run(["opencli", "plugin", "uninstall", name], check=False)
            print(f"reinstalling opencli plugin: {name}", flush=True)
            subprocess.run(["opencli", "plugin", "uninstall", name], check=False)
        else:
            print(f"installing opencli plugin: {name}", flush=True)
        subprocess.run(["opencli", "plugin", "install", source.as_uri()], check=True)


desired, metas = discover_skills()
validate_dependencies(desired, metas)

if sync_skills:
    link_skills(desired)
else:
    print("skipped skill link sync", flush=True)

if sync_tools:
    install_opencli_plugins(iter_opencli_plugins(desired, metas))
else:
    print("skipped tool/plugin sync", flush=True)

if check_only:
    print(f"check ok: {len(desired)} skills, {len(metas)} metadata files", flush=True)
else:
    print(f"skill sync complete: {len(desired)} repo skills", flush=True)
PY
