#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
default_skill_targets="$HOME/.agents/skills:$HOME/.claude/skills"
sync_skills=1
sync_tools=1
check_only=0

if [ -z "${AGENT_SKILLS_SKILL_TARGETS:-}" ]; then
  AGENT_SKILLS_SKILL_TARGETS="${AGENT_HUB_SKILL_TARGETS:-$default_skill_targets}"
fi
export AGENT_SKILLS_SKILL_TARGETS

usage() {
  cat <<'EOF'
Usage:
  ./scripts/skill-sync [--skills-only|--tools-only|--no-tools|--check]

This repo is the canonical source for owned and mirror skills. Ownership is
recorded in skill-manifest.json and never inferred from a directory name.
Mirror skills are replaceable upstream copies; owned skills remain local-first.

Options:
  --skills-only      Link repo skills only; skip tool/plugin install.
  --personal-only    Back-compat alias for --skills-only.
  --private-only     Back-compat alias for --skills-only.
  --tools-only       Install declared tools/plugins only; skip skill links.
  --no-tools         Link repo skills and skip tool/plugin install.
  --check            Validate model, runtime links, and plugin state without changes.
  -h, --help         Show this help.

Deprecated:
  --thirdparty-only, --install, --remove are no longer supported. Edit
  skill-manifest.json and the canonical skills/ source, then run skill-sync.
EOF
}

die() {
  echo "$1" >&2
  usage >&2
  exit 1
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --skills-only|--personal-only|--private-only)
      sync_skills=1
      sync_tools=0
      shift
      ;;
    --tools-only)
      sync_skills=0
      sync_tools=1
      shift
      ;;
    --no-tools)
      sync_tools=0
      shift
      ;;
    --check)
      check_only=1
      shift
      ;;
    --thirdparty-only|--install|--remove|--install=*|--remove=*)
      die "$1 is deprecated: manage ownership and source relations through skill-manifest.json"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required" >&2
  exit 1
fi

python3 - "$repo_root" "$AGENT_SKILLS_SKILL_TARGETS" "$sync_skills" "$sync_tools" "$check_only" <<'PY'
import os
import shutil
import subprocess
import sys
from pathlib import Path

repo_root = Path(sys.argv[1]).resolve()
skills_root = repo_root / "skills"
sys.path.insert(0, str(repo_root / "scripts"))
from skill_model import ModelError, load_catalog
target_roots = [
    Path(os.path.expanduser(item)).resolve()
    for item in sys.argv[2].split(os.pathsep)
    if item
]
if not target_roots:
    raise SystemExit("AGENT_SKILLS_SKILL_TARGETS must contain at least one target directory")
sync_skills = sys.argv[3] == "1"
sync_tools = sys.argv[4] == "1"
check_only = sys.argv[5] == "1"


def under(path: Path, parent: Path) -> bool:
    try:
        path.relative_to(parent)
        return True
    except ValueError:
        return False


def resolve(path: Path) -> Path:
    return path.resolve(strict=False)


def managed_runtime_target(path: Path) -> bool:
    return under(path, skills_root) or any(under(path, root) for root in target_roots)


def link_skills(desired: dict, records: dict):
    if check_only:
        errors = []
        for target_root in target_roots:
            if not target_root.is_dir():
                errors.append(f"missing runtime skill root: {target_root}")
                continue
            for name, source in sorted(desired.items()):
                target = target_root / name
                if not target.is_symlink():
                    kind = "missing" if not target.exists() else "not a symlink"
                    errors.append(f"{target}: {kind}")
                elif resolve(target) != resolve(source):
                    errors.append(f"{target}: points to {resolve(target)}, expected {resolve(source)}")
            for child in target_root.iterdir():
                if not child.is_symlink() or child.name in desired:
                    continue
                if managed_runtime_target(resolve(child)):
                    errors.append(f"stale runtime skill link: {child} -> {resolve(child)}")
        if errors:
            raise SystemExit("runtime skill link check failed:\n- " + "\n- ".join(errors))
        return

    for target_root in target_roots:
        target_root.mkdir(parents=True, exist_ok=True)
        for child in target_root.iterdir():
            if not child.is_symlink():
                continue
            linked_target = resolve(child)
            stale_deleted = child.name not in desired and managed_runtime_target(linked_target)
            stale_repo_link = (
                child.name in desired
                and under(linked_target, skills_root)
                and resolve(desired[child.name]) != linked_target
            )
            if stale_deleted or stale_repo_link:
                child.unlink()
                print(f"removed stale skill link: {child}", flush=True)

        for name, source in sorted(desired.items()):
            target = target_root / name
            if target.exists() or target.is_symlink():
                if target.is_symlink():
                    linked_target = resolve(target)
                    if linked_target == resolve(source):
                        continue
                    if managed_runtime_target(linked_target):
                        target.unlink()
                    elif records[name].ownership == "mirror":
                        old_target = os.readlink(target)
                        target.unlink()
                        print(f"replaced external mirror symlink with repo link: {target} (was {old_target})", flush=True)
                    else:
                        raise SystemExit(
                            f"error: {target} already exists as an unmanaged symlink "
                            f"to {os.readlink(target)}"
                        )
                else:
                    may_replace_managed_copy = (
                        target.is_dir()
                        and (target / "SKILL.md").exists()
                        and os.environ.get("AGENT_SKILLS_REPLACE_EXISTING_SKILL_DIRS") == "1"
                    )
                    if may_replace_managed_copy:
                        shutil.rmtree(target)
                        print(f"replaced installed skill copy with repo link: {target}", flush=True)
                    else:
                        raise SystemExit(f"error: {target} already exists and is not an agent_skills symlink")
            os.symlink(source, target, target_is_directory=True)
            print(f"linked skill: {target} -> {source}", flush=True)


def iter_opencli_plugins(records: dict):
    seen = {}
    for skill_name, record in sorted(records.items()):
        for relation in record.tool_relations:
            tool = relation.get("tool") or {}
            if tool.get("kind") != "opencli-plugin":
                continue
            plugin_name = tool["name"]
            path = (record.path / tool["path"]).resolve()
            if plugin_name in seen and seen[plugin_name] != path:
                raise SystemExit(f"opencli plugin {plugin_name!r} declared with multiple paths: {seen[plugin_name]} and {path}")
            seen[plugin_name] = path
    return sorted(seen.items())


def install_opencli_plugins(plugins):
    if not plugins:
        return
    if shutil.which("opencli") is None:
        raise SystemExit("opencli is required to install declared opencli-plugin tools")
    plugins_root = Path.home() / ".opencli" / "plugins"
    for name, source in plugins:
        target = plugins_root / name
        if check_only:
            if not target.is_symlink() or resolve(target) != source:
                raise SystemExit(f"opencli plugin link check failed: {target} must point to {source}")
            host_link = source / "node_modules" / "@jackwener" / "opencli"
            if not (host_link.exists() or host_link.is_symlink()):
                raise SystemExit(f"opencli plugin runtime link is missing: {host_link}")
            continue
        if target.exists() or target.is_symlink():
            if target.is_symlink() and resolve(target) == source:
                host_link = source / "node_modules" / "@jackwener" / "opencli"
                if host_link.exists() or host_link.is_symlink():
                    print(f"opencli plugin already linked: {name} -> {source}", flush=True)
                    continue
                print(f"repairing opencli plugin runtime link: {name}", flush=True)
                subprocess.run(["opencli", "plugin", "uninstall", name], check=False)
            print(f"reinstalling opencli plugin: {name}", flush=True)
            subprocess.run(["opencli", "plugin", "uninstall", name], check=False)
        else:
            print(f"installing opencli plugin: {name}", flush=True)
        subprocess.run(["opencli", "plugin", "install", source.as_uri()], check=True)


try:
    catalog = load_catalog(repo_root)
except ModelError as error:
    raise SystemExit(str(error))
desired = {name: record.path for name, record in catalog.skills.items()}
records = catalog.skills

if sync_skills:
    link_skills(desired, records)
else:
    print("skipped skill link sync", flush=True)

if sync_tools:
    install_opencli_plugins(iter_opencli_plugins(records))
else:
    print("skipped tool/plugin sync", flush=True)

if check_only:
    print(
        f"check ok: {len(desired)} skills; "
        f"{catalog.explicit_ownership_count} explicit ownership records, "
        f"{catalog.legacy_source_count} legacy source records",
        flush=True,
    )
else:
    print(f"skill sync complete: {len(desired)} repo skills", flush=True)
PY
