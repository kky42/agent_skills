#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
private_skills="$repo_root/skills"
manifest="$repo_root/thirdparty-skills.yml"
lock_file="${XDG_STATE_HOME:-$HOME/.agents}/skills/.skill-lock.json"
default_private_targets="$HOME/.agents/skills:$HOME/.claude/skills"
sync_private=1
sync_thirdparty=1
thirdparty_action=sync
thirdparty_skill=
personal_only_requested=0
thirdparty_only_requested=0

: "${AGENT_HUB_SKILL_TARGETS:=$default_private_targets}"
: "${AGENT_HUB_THIRDPARTY_SYNC_SLEEP_SECONDS:=5}"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/skill-sync [--personal-only|--private-only]
  ./scripts/skill-sync [--thirdparty-only]
  ./scripts/skill-sync --thirdparty-only --install <skill>
  ./scripts/skill-sync --thirdparty-only --remove <skill>

Options:
  --personal-only    Link personal skills only; skip third-party npx skills sync.
  --private-only     Alias for --personal-only.
  --thirdparty-only  Sync third-party skills only; skip personal skill links.
  --install <skill>  Install/update one third-party skill from the manifest.
  --remove <skill>   Remove one third-party skill after deleting it from the manifest.
  -h, --help         Show this help.
EOF
}

die() {
  echo "$1" >&2
  usage >&2
  exit 1
}

set_thirdparty_action() {
  local action="$1"
  local skill="$2"

  if [ -z "$skill" ]; then
    die "--$action requires a skill name"
  fi
  if [ "$personal_only_requested" -eq 1 ]; then
    die "--$action cannot be combined with --personal-only"
  fi
  if [ "$thirdparty_action" != "sync" ]; then
    die "only one of --install or --remove may be used"
  fi

  thirdparty_action="$action"
  thirdparty_skill="$skill"
  sync_private=0
  sync_thirdparty=1
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --personal-only|--private-only)
      if [ "$thirdparty_only_requested" -eq 1 ]; then
        die "--personal-only cannot be combined with --thirdparty-only"
      fi
      if [ "$thirdparty_action" != "sync" ]; then
        die "--personal-only cannot be combined with --$thirdparty_action"
      fi
      personal_only_requested=1
      sync_private=1
      sync_thirdparty=0
      shift
      ;;
    --thirdparty-only)
      if [ "$personal_only_requested" -eq 1 ]; then
        die "--thirdparty-only cannot be combined with --personal-only"
      fi
      thirdparty_only_requested=1
      sync_private=0
      sync_thirdparty=1
      shift
      ;;
    --install)
      if [ "$#" -lt 2 ]; then
        die "--install requires a skill name"
      fi
      set_thirdparty_action install "$2"
      shift 2
      ;;
    --install=*)
      set_thirdparty_action install "${1#--install=}"
      shift
      ;;
    --remove)
      if [ "$#" -lt 2 ]; then
        die "--remove requires a skill name"
      fi
      set_thirdparty_action remove "$2"
      shift 2
      ;;
    --remove=*)
      set_thirdparty_action remove "${1#--remove=}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [ "$thirdparty_action" != "sync" ] && [ "$thirdparty_only_requested" -ne 1 ]; then
  die "--install and --remove require --thirdparty-only"
fi

if [ -z "${XDG_STATE_HOME:-}" ]; then
  lock_file="$HOME/.agents/.skill-lock.json"
fi

mkdir -p "$private_skills"

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required" >&2
  exit 1
fi

if [ "$sync_private" -eq 1 ]; then
python3 - "$private_skills" "$AGENT_HUB_SKILL_TARGETS" <<'PY'
import os
import shutil
import sys
from pathlib import Path

private_root = Path(sys.argv[1]).resolve()
target_roots = [
    Path(os.path.expanduser(item)).resolve()
    for item in sys.argv[2].split(os.pathsep)
    if item
]
legacy_roots = target_roots + [Path.home() / ".pi" / "agent" / "skills"]


def under(path: Path, parent: Path) -> bool:
    try:
        path.relative_to(parent)
        return True
    except ValueError:
        return False


def resolve(path: Path) -> Path:
    return path.resolve(strict=False)


def clean_scalar(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
        return value[1:-1]
    return value


def frontmatter_name(skill_md: Path):
    lines = skill_md.read_text(encoding="utf-8").splitlines()
    if not lines or lines[0].strip() != "---":
        return None

    for line in lines[1:]:
        if line.strip() == "---":
            return None
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or ":" not in stripped:
            continue
        key, value = stripped.split(":", 1)
        if key.strip() == "name":
            name = clean_scalar(value)
            return str(name) if name else None

    return None


desired = {}
for skill_md in sorted(private_root.rglob("SKILL.md")):
    skill_dir = skill_md.parent.resolve()
    name = skill_dir.name

    if name in desired:
        raise SystemExit(
            f"duplicate private skill directory name: {name}\n"
            f"  {desired[name]}\n"
            f"  {skill_dir}"
        )

    declared_name = frontmatter_name(skill_md)
    if declared_name and declared_name != name:
        raise SystemExit(
            f"{skill_md}: frontmatter name {declared_name!r} "
            f"does not match directory name {name!r}"
        )

    desired[name] = skill_dir

seen_legacy_roots = set()
for root in legacy_roots:
    root = root.resolve()
    if root in seen_legacy_roots:
        continue
    seen_legacy_roots.add(root)

    for legacy_name in ("agent_hub-private", "agent_hub_skills"):
        legacy_path = root / legacy_name
        if legacy_path.is_symlink():
            legacy_path.unlink()
            print(f"removed legacy private skill link: {legacy_path}", flush=True)
        elif legacy_path.is_dir():
            shutil.rmtree(legacy_path)
            print(f"removed legacy private skill copy: {legacy_path}", flush=True)

for target_root in target_roots:
    target_root.mkdir(parents=True, exist_ok=True)

    for child in target_root.iterdir():
        if not child.is_symlink():
            continue

        linked_target = resolve(child)
        if not under(linked_target, private_root):
            continue

        if child.name not in desired or resolve(desired[child.name]) != linked_target:
            child.unlink()
            print(f"removed stale private skill link: {child}", flush=True)

    for name, source in sorted(desired.items()):
        target = target_root / name

        if target.exists() or target.is_symlink():
            if target.is_symlink():
                linked_target = resolve(target)
                if linked_target == resolve(source):
                    continue
                if under(linked_target, private_root):
                    target.unlink()
                else:
                    raise SystemExit(
                        f"error: {target} already exists as an unmanaged symlink "
                        f"to {os.readlink(target)}"
                    )
            else:
                raise SystemExit(
                    f"error: {target} already exists and is not an agent_hub symlink"
                )

        os.symlink(source, target, target_is_directory=True)
        print(f"linked private skill: {target} -> {source}", flush=True)
PY
else
  echo "skipped personal skill sync"
fi

if [ "$sync_thirdparty" -eq 0 ]; then
  echo "skipped third-party skill sync"
  exit 0
fi

if ! command -v npx >/dev/null 2>&1; then
  echo "npx is required" >&2
  exit 1
fi

python3 - "$manifest" "$lock_file" "$thirdparty_action" "$thirdparty_skill" <<'PY'
import json
import os
import subprocess
import sys
import time
from pathlib import Path

manifest = Path(sys.argv[1])
lock_file = Path(sys.argv[2])
action = sys.argv[3]
target_skill = sys.argv[4]
sleep_seconds = float(os.environ.get("AGENT_HUB_THIRDPARTY_SYNC_SLEEP_SECONDS", "5"))

def clean_scalar(value: str):
    value = value.strip()
    if " #" in value:
        value = value.split(" #", 1)[0].rstrip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
        return value[1:-1]
    lowered = value.lower()
    if lowered == "true":
        return True
    if lowered == "false":
        return False
    return value


def load_manifest(path: Path):
    if not path.exists():
        return {"skills": []}

    skills = []
    current = None
    current_list_key = None

    for line_no, raw in enumerate(path.read_text(encoding="utf-8").splitlines(), 1):
        stripped = raw.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if stripped.startswith("skills:"):
            current = None
            current_list_key = None
            continue
        if stripped.startswith("- "):
            item = stripped[2:].strip()
            if ":" in item:
                key, value = item.split(":", 1)
                if key.strip() == "skill":
                    current = {"skill": clean_scalar(value)}
                    skills.append(current)
                    current_list_key = None
                    continue
            if current is None or current_list_key is None:
                raise SystemExit(f"{path}:{line_no}: list item without a list key")
            current.setdefault(current_list_key, []).append(clean_scalar(item))
            continue
        if current is None:
            raise SystemExit(f"{path}:{line_no}: expected a skill entry")
        if ":" not in stripped:
            raise SystemExit(f"{path}:{line_no}: expected key: value")
        key, value = stripped.split(":", 1)
        key = key.strip()
        if value.strip():
            current[key] = clean_scalar(value)
            current_list_key = None
        else:
            current[key] = []
            current_list_key = key

    return {"skills": skills}


data = load_manifest(manifest)
skills = data.get("skills") or []

desired = {}
for item in skills:
    if not item.get("skill"):
        raise SystemExit("thirdparty-skills.yml entry is missing skill")
    if not item.get("source"):
        raise SystemExit(f"{item['skill']}: missing source")
    agents = item.get("agents") or []
    if not agents:
        raise SystemExit(f"{item['skill']}: missing agents")
    desired[item["skill"]] = item

lock_data = {"version": 3, "skills": {}}
locked = {}
if lock_file.exists():
    try:
        lock_data = json.loads(lock_file.read_text())
        locked = (lock_data.get("skills") or {})
    except json.JSONDecodeError:
        raise SystemExit(f"invalid npx skills lock file: {lock_file}")

def save_lock():
    lock_data["skills"] = locked
    lock_file.parent.mkdir(parents=True, exist_ok=True)
    lock_file.write_text(
        json.dumps(lock_data, indent=2, ensure_ascii=False) + "\n"
    )


def run_remove(name: str, stale: bool = False):
    if stale:
        print(f"removing stale third-party skill: {name}", flush=True)
    else:
        print(f"removing third-party skill: {name}", flush=True)

    result = subprocess.run(
        ["npx", "skills", "remove", name, "-g", "-y"],
        capture_output=True,
        text=True,
    )
    if result.stdout:
        print(result.stdout, end="")
    if result.stderr:
        print(result.stderr, end="", file=sys.stderr)
    if result.returncode != 0 and "No matching skills found" not in (result.stdout + result.stderr):
        raise SystemExit(result.returncode)

    removed_from_lock = name in locked
    locked.pop(name, None)
    return removed_from_lock


def install_args(name: str, item: dict):
    args = ["npx", "skills", "add", item["source"], "-g", "-y"]
    args += ["--skill", name]
    if item.get("agents"):
        args += ["--agent"] + list(item["agents"])
    if item.get("copy", False):
        args += ["--copy"]
    return args


def run_install(name: str, item: dict):
    print(f"installing third-party skill: {name}", flush=True)
    return subprocess.run(install_args(name, item)).returncode


if action == "install":
    if target_skill not in desired:
        raise SystemExit(
            f"{target_skill}: not found in thirdparty-skills.yml; "
            "add the manifest entry before running --install"
        )

    raise SystemExit(run_install(target_skill, desired[target_skill]))

if action == "remove":
    if target_skill in desired:
        raise SystemExit(
            f"{target_skill}: still listed in thirdparty-skills.yml; "
            "remove the manifest entry before running --remove"
        )

    if run_remove(target_skill):
        save_lock()
    raise SystemExit(0)

if not desired and locked:
    if os.environ.get("AGENT_HUB_CONFIRM_EMPTY_THIRDPARTY") != "1":
        raise SystemExit(
            "thirdparty-skills.yml is empty, but npx skills has global skills "
            "in its lock file. Run ./scripts/skill-migrate first, "
            "or set AGENT_HUB_CONFIRM_EMPTY_THIRDPARTY=1 to remove all "
            "npx-managed global skills."
        )

removed_from_lock = False
for name in sorted(list(locked)):
    if name not in desired:
        if run_remove(name, stale=True):
            removed_from_lock = True

if removed_from_lock:
    save_lock()

failed_installs = []
for index, (name, item) in enumerate(sorted(desired.items())):
    returncode = run_install(name, item)
    if returncode != 0:
        failed_installs.append((name, item["source"], returncode))
        print(
            f"warning: failed to install third-party skill {name!r} "
            f"from {item['source']!r}; continuing",
            file=sys.stderr,
            flush=True,
        )
    if sleep_seconds > 0 and index < len(desired) - 1:
        time.sleep(sleep_seconds)

if failed_installs:
    print(
        "warning: third-party sync completed with failed install/update(s):",
        file=sys.stderr,
        flush=True,
    )
    for name, source, returncode in failed_installs:
        print(
            f"  - {name} from {source} exited with {returncode}",
            file=sys.stderr,
            flush=True,
        )
PY
