#!/usr/bin/env bash
set -euo pipefail

if [ "${1:-}" != "--legacy-write" ] || [ "$#" -ne 1 ]; then
  cat >&2 <<'EOF'
skill-migrate is legacy/import-only and cannot infer mirror vs owned.
It writes only the frozen v1 thirdparty manifest. If a one-time legacy import
is truly required, rerun: ./scripts/skill-migrate --legacy-write
EOF
  exit 2
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
manifest="$repo_root/thirdparty-skills.yml"
lock_file="${XDG_STATE_HOME:-$HOME/.agents}/skills/.skill-lock.json"

if [ -z "${XDG_STATE_HOME:-}" ]; then
  lock_file="$HOME/.agents/.skill-lock.json"
fi

if ! command -v npx >/dev/null 2>&1; then
  echo "npx is required" >&2
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required" >&2
  exit 1
fi

python3 - "$manifest" "$lock_file" <<'PY'
import json
import subprocess
import sys
from pathlib import Path

manifest = Path(sys.argv[1])
lock_file = Path(sys.argv[2])

agent_name_to_slug = {
    "Claude Code": "claude-code",
    "Codex": "codex",
}

def clean_scalar(value: str):
    value = value.strip()
    if " #" in value:
        value = value.split(" #", 1)[0].rstrip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
        return value[1:-1]
    lowered = value.lower()
    if lowered == "true":
        return True
    if lowered == "false":
        return False
    return value


def load_manifest(path: Path):
    if not path.exists():
        return {"skills": []}

    skills = []
    current = None
    current_list_key = None

    for line_no, raw in enumerate(path.read_text(encoding="utf-8").splitlines(), 1):
        stripped = raw.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if stripped.startswith("skills:"):
            current = None
            current_list_key = None
            continue
        if stripped.startswith("- "):
            item = stripped[2:].strip()
            if ":" in item:
                key, value = item.split(":", 1)
                if key.strip() == "skill":
                    current = {"skill": clean_scalar(value)}
                    skills.append(current)
                    current_list_key = None
                    continue
            if current is None or current_list_key is None:
                raise SystemExit(f"{path}:{line_no}: list item without a list key")
            current.setdefault(current_list_key, []).append(clean_scalar(item))
            continue
        if current is None:
            raise SystemExit(f"{path}:{line_no}: expected a skill entry")
        if ":" not in stripped:
            raise SystemExit(f"{path}:{line_no}: expected key: value")
        key, value = stripped.split(":", 1)
        key = key.strip()
        if value.strip():
            current[key] = clean_scalar(value)
            current_list_key = None
        else:
            current[key] = []
            current_list_key = key

    return {"skills": skills}


def dump_manifest(data):
    lines = ["skills:"]
    for item in data.get("skills") or []:
        lines.append(f"- skill: {item['skill']}")
        lines.append(f"  source: {item['source']}")
        lines.append("  agents:")
        for agent in item.get("agents") or []:
            lines.append(f"  - {agent}")
        if item.get("copy", False):
            lines.append("  copy: true")
    return "\n".join(lines) + "\n"


existing = load_manifest(manifest)
existing_skills = {
    item["skill"]: item
    for item in (existing or {}).get("skills", [])
    if isinstance(item, dict) and item.get("skill")
}

locked = {}
if lock_file.exists():
    locked = (json.loads(lock_file.read_text()).get("skills") or {})

listed = json.loads(
    subprocess.run(
        ["npx", "skills", "ls", "-g", "--json"],
        check=True,
        capture_output=True,
        text=True,
    ).stdout
)

listed_agents = {}
for item in listed:
    name = item.get("name")
    if not name:
        continue
    agents = []
    for agent in item.get("agents") or []:
        slug = agent_name_to_slug.get(agent)
        if slug and slug not in agents:
            agents.append(slug)
    listed_agents[name] = agents

for name, entry in sorted(locked.items()):
    if name in existing_skills:
        continue
    source = entry.get("source")
    if not source:
        continue
    agents = listed_agents.get(name) or ["codex", "claude-code"]
    existing_skills[name] = {
        "skill": name,
        "source": source,
        "agents": agents,
    }

output = {
    "skills": [existing_skills[name] for name in sorted(existing_skills)]
}

manifest.write_text(dump_manifest(output), encoding="utf-8")
print(f"wrote {len(output['skills'])} legacy source record(s) to {manifest}")
PY
