{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kky42.com/schemas/agent-skills/skill-manifest.schema.json",
  "title": "agent_skills ownership and relation manifest",
  "type": "object",
  "required": ["schemaVersion", "sources", "skills"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "sources": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/gitSource" }
    },
    "skills": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/skill" }
    }
  },
  "$defs": {
    "gitSource": {
      "type": "object",
      "required": ["kind", "url"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "git" },
        "url": { "type": "string", "minLength": 1 },
        "defaultRef": { "type": "string", "minLength": 1 }
      }
    },
    "sourceLocator": {
      "type": "object",
      "required": ["source", "path"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 }
      }
    },
    "watch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "exclude": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "localPaths": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "localConcerns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "contentRelation": {
      "type": "object",
      "required": ["id", "type", "source"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "enum": ["content-source", "reference"] },
        "source": { "$ref": "#/$defs/sourceLocator" },
        "watch": { "$ref": "#/$defs/watch" }
      }
    },
    "skillDependency": {
      "type": "object",
      "required": ["id", "type", "skill"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "const": "skill-dependency" },
        "skill": { "type": "string", "minLength": 1 },
        "verify": {
          "type": "array",
          "items": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "toolDependency": {
      "type": "object",
      "required": ["id", "type", "tool"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "const": "tool-dependency" },
        "tool": {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "package": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 },
            "constraint": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        },
        "updatePolicy": { "enum": ["manual", "compatible", "latest", "pinned"] },
        "verify": {
          "type": "array",
          "items": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "relation": {
      "oneOf": [
        { "$ref": "#/$defs/contentRelation" },
        { "$ref": "#/$defs/skillDependency" },
        { "$ref": "#/$defs/toolDependency" }
      ]
    },
    "mirrorSkill": {
      "type": "object",
      "required": ["ownership", "mirror"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "ownership": { "const": "mirror" },
        "mirror": { "$ref": "#/$defs/sourceLocator" }
      }
    },
    "ownedSkill": {
      "type": "object",
      "required": ["ownership"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "ownership": { "const": "owned" },
        "relations": {
          "type": "array",
          "items": { "$ref": "#/$defs/relation" }
        }
      }
    },
    "skill": {
      "oneOf": [
        { "$ref": "#/$defs/mirrorSkill" },
        { "$ref": "#/$defs/ownedSkill" }
      ]
    }
  }
}
