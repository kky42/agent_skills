{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kky42.com/schemas/agent-skills/skill-lock.schema.json",
  "title": "agent_skills resolved update and review state",
  "type": "object",
  "required": ["schemaVersion", "skills"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "skills": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/skillState" }
    }
  },
  "$defs": {
    "acceptedDecision": {
      "type": "object",
      "required": ["upstreamPaths", "localPaths", "note"],
      "additionalProperties": false,
      "properties": {
        "upstreamPaths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "localPaths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "skippedDecision": {
      "type": "object",
      "required": ["upstreamPaths", "reason"],
      "additionalProperties": false,
      "properties": {
        "upstreamPaths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "review": {
      "type": "object",
      "required": ["fromCommit", "toCommit", "relationFingerprint", "accepted", "skipped", "reviewedAt"],
      "additionalProperties": false,
      "properties": {
        "fromCommit": { "type": ["string", "null"] },
        "toCommit": { "type": "string", "minLength": 7 },
        "relationFingerprint": { "type": "string", "pattern": "^sha256:" },
        "accepted": { "type": "array", "items": { "$ref": "#/$defs/acceptedDecision" } },
        "skipped": { "type": "array", "items": { "$ref": "#/$defs/skippedDecision" } },
        "note": { "type": "string" },
        "reviewedAt": { "type": "string", "format": "date-time" }
      }
    },
    "relationState": {
      "type": "object",
      "required": ["relationFingerprint", "sourceId", "sourcePath", "sourceRef", "lastReviewedCommit", "reviewedAt", "reviews"],
      "additionalProperties": false,
      "properties": {
        "relationFingerprint": { "type": "string", "pattern": "^sha256:" },
        "sourceId": { "type": "string", "minLength": 1 },
        "sourcePath": { "type": "string", "minLength": 1 },
        "sourceRef": { "type": "string", "minLength": 1 },
        "lastReviewedCommit": { "type": "string", "minLength": 7 },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "reviews": { "type": "array", "items": { "$ref": "#/$defs/review" } }
      }
    },
    "mirrorState": {
      "type": "object",
      "required": ["resolvedCommit", "sourcePath", "upstreamHash", "materializedHash", "syncedAt"],
      "additionalProperties": false,
      "properties": {
        "resolvedCommit": { "type": "string", "minLength": 7 },
        "sourcePath": { "type": "string", "minLength": 1 },
        "upstreamHash": { "type": "string", "pattern": "^sha256:" },
        "materializedHash": { "type": "string", "pattern": "^sha256:" },
        "syncedAt": { "type": "string", "format": "date-time" }
      }
    },
    "skillState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mirror": { "$ref": "#/$defs/mirrorState" },
        "relations": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/relationState" }
        }
      }
    }
  }
}
