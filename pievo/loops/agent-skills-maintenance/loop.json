{
  "apiVersion": "pievo.dev/v1",
  "kind": "Loop",
  "metadata": {
    "name": "agent-skills-maintenance",
    "description": "Half-day gate loop that checks mirror integrity, owned-source review debt, runtime skill links, and maintenance evidence."
  },
  "spec": {
    "initial_status": "paused",
    "initial_phase": "bootstrap",
    "entrypoints": {
      "work": {
        "workflow": "workflows/work.js",
        "cadence": { "kind": "interval", "seconds": 43200 },
        "timeout_minutes": 45,
        "dispatch_probe": {
          "command": "node ${PIEVO_GENERATION_DIR}/assets/probe/maintenance-debt.mjs ${PIEVO_WORKSPACE_DIR}",
          "timeout_seconds": 600,
          "eval_anchor": { "mode": "generation_asset", "paths": ["assets/probe/maintenance-debt.mjs"] }
        },
        "local_eval": {
          "required": true,
          "core_checks": [
            {
              "name": "maintenance-invariants",
              "command": "node ${PIEVO_GENERATION_DIR}/assets/eval/maintenance-check.mjs",
              "cwd": "${PIEVO_RUN_DIR}",
              "timeout_minutes": 20,
              "eval_anchor": { "mode": "generation_asset", "paths": ["assets/eval/maintenance-check.mjs"] },
              "candidate_inputs": ["AGENTS.md", "README.md", "CONTEXT.md", "skill-manifest.json", "skill-lock.json", "schemas/**", "scripts/**", "tests/**", "skills/**", "maintenance/**"],
              "metric_extractors": [
                { "metric_name": "skill_model_ok", "goal_name": "skill_model_ok", "kind": "json_pointer", "file": "metrics.json", "pointer": "/metrics/skill_model_ok", "source": "local_eval", "higher_is_better": true },
                { "metric_name": "sync_ok", "goal_name": "sync_ok", "kind": "json_pointer", "file": "metrics.json", "pointer": "/metrics/sync_ok", "source": "local_eval", "higher_is_better": true },
                { "metric_name": "scripts_ok", "goal_name": "scripts_ok", "kind": "json_pointer", "file": "metrics.json", "pointer": "/metrics/scripts_ok", "source": "local_eval", "higher_is_better": true },
                { "metric_name": "chatgpt_static_ok", "goal_name": "chatgpt_static_ok", "kind": "json_pointer", "file": "metrics.json", "pointer": "/metrics/chatgpt_static_ok", "source": "local_eval", "higher_is_better": true },
                { "metric_name": "evidence_ok", "goal_name": "evidence_ok", "kind": "json_pointer", "file": "metrics.json", "pointer": "/metrics/evidence_ok", "source": "local_eval", "higher_is_better": true }
              ]
            }
          ]
        }
      },
      "recalibrate": { "workflow": "workflows/recalibrate.js", "cadence": { "kind": "manual" }, "timeout_minutes": 10 },
      "repair": { "workflow": "workflows/repair.js", "cadence": { "kind": "manual" }, "timeout_minutes": 20 }
    },
    "side_workflows": {},
    "effect_handlers": {},
    "secrets": {},
    "workspace": { "import": { "mode": "copy" }, "run_isolation": "copy" },
    "measurement": {
      "metrics": {
        "skill_model_ok": { "source": "local_eval", "higher_is_better": true },
        "sync_ok": { "source": "local_eval", "higher_is_better": true },
        "scripts_ok": { "source": "local_eval", "higher_is_better": true },
        "chatgpt_static_ok": { "source": "local_eval", "higher_is_better": true },
        "evidence_ok": { "source": "local_eval", "higher_is_better": true }
      },
      "calibration": { "mode": "identity" }
    },
    "goals": [
      { "name": "skill_model_ok", "kind": "primary", "metric_name": "skill_model_ok", "source": "local_eval", "higher_is_better": true, "target": 1, "epsilon": 0, "missing_policy": "block" },
      { "name": "sync_ok", "kind": "auxiliary", "metric_name": "sync_ok", "source": "local_eval", "higher_is_better": true, "target": 1, "epsilon": 0, "missing_policy": "block" },
      { "name": "scripts_ok", "kind": "auxiliary", "metric_name": "scripts_ok", "source": "local_eval", "higher_is_better": true, "target": 1, "epsilon": 0, "missing_policy": "block" },
      { "name": "chatgpt_static_ok", "kind": "auxiliary", "metric_name": "chatgpt_static_ok", "source": "local_eval", "higher_is_better": true, "target": 1, "epsilon": 0, "missing_policy": "block" },
      { "name": "evidence_ok", "kind": "auxiliary", "metric_name": "evidence_ok", "source": "local_eval", "higher_is_better": true, "target": 1, "epsilon": 0, "missing_policy": "block" }
    ],
    "decision": { "mode": "gate" },
    "audit": { "bootstrap": { "min_trials": 1, "allow_effects": false } },
    "contracts": {
      "protect_loop_evaluators": {
        "kind": "surface",
        "denyWrite": ["pievo/loops/agent-skills-maintenance/assets/**", "pievo/loops/agent-skills-maintenance/loop.json", "scripts/**", "schemas/**", "tests/**", "skill-manifest.json"],
        "consequence": "block"
      }
    },
    "retention": {}
  }
}
